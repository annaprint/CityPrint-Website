function HeroCalculator({ navigate }) {
  const [product, setProduct] = useStateH('books');
  const [qty, setQty] = useStateH(100);
  const [pages, setPages] = useStateH(64);
  const [paper, setPaper] = useStateH('standard');
  const [finish, setFinish] = useStateH('none');

  const price = useMemoH(() => {
    const base = PRICE_BASE[product] || { base: 100, per: 50 };
    const paperMult = paper === 'premium' ? 1.6 : paper === 'eco' ? 1.2 : 1;
    const finishMult = finish === 'foil' ? 1.35 : finish === 'emboss' ? 1.25 : finish === 'laminate' ? 1.1 : 1;
    const pageMult = (product === 'books' || product === 'catalogs') ? (0.5 + pages / 128) : 1;
    const totalPerUnit = base.per * paperMult * finishMult * pageMult;
    const setup = base.base * paperMult * finishMult;
    const total = Math.round(setup + totalPerUnit * qty);
    const low = Math.round(total * 0.9);
    const high = Math.round(total * 1.15);
    return { total, low, high };
  }, [product, qty, pages, paper, finish]);

  const showPages = product === 'books' || product === 'catalogs';
  const fmt = (n) => n.toLocaleString('ru-RU');

  return (
    <section className="hero">
      <div className="wrap hero-grid">
        <div>
          <div className="eyebrow" style={{ marginBottom: 28 }}>Расчёт за 10 секунд</div>
          <h1 className="hero-title">
            <WordReveal words={[
              { text: 'Сколько' }, { text: 'стоит' },
              { text: 'ваш', italic: true }, { text: 'тираж?', italic: true },
            ]} />
          </h1>
          <p className="hero-sub">Выберите тип продукции и параметры — увидите оценку стоимости прямо сейчас. Точная цена после брифа.</p>
          <div style={{ display: 'flex', gap: 12, marginTop: 32, flexWrap: 'wrap' }}>
            <a href="#cta" className="btn primary" onClick={(e) => { e.preventDefault(); document.getElementById('cta')?.scrollIntoView({behavior: 'smooth'}); }}>Отправить бриф</a>
            <a href="#" className="btn ghost" onClick={(e) => { e.preventDefault(); navigate('portfolio'); }}>Портфолио →</a>
          </div>
        </div>
        <div className="calc-card">
          <div className="eyebrow">Калькулятор</div>
          <h3 style={{ marginTop: 6 }}>Оценка стоимости</h3>
          <div className="calc-row" style={{ gridTemplateColumns: '1fr' }}>
            <div className="calc-field">
              <label>Тип продукции</label>
              <select value={product} onChange={(e) => setProduct(e.target.value)}>
                {PRODUCTS.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}
              </select>
            </div>
          </div>
          <div className="calc-row">
            <div className="calc-field">
              <label>Тираж</label>
              <input type="number" min="1" value={qty} onChange={(e) => setQty(Math.max(1, +e.target.value || 1))} />
            </div>
            {showPages ? (
              <div className="calc-field">
                <label>Страниц</label>
                <input type="number" min="8" step="8" value={pages} onChange={(e) => setPages(Math.max(8, +e.target.value || 8))} />
              </div>
            ) : (
              <div className="calc-field">
                <label>Отделка</label>
                <select value={finish} onChange={(e) => setFinish(e.target.value)}>
                  <option value="none">Без отделки</option>
                  <option value="laminate">Ламинация</option>
                  <option value="foil">Тиснение фольгой</option>
                  <option value="emboss">Конгрев</option>
                </select>
              </div>
            )}
          </div>
          <div className="calc-row">
            <div className="calc-field">
              <label>Бумага</label>
              <select value={paper} onChange={(e) => setPaper(e.target.value)}>
                <option value="standard">Стандартная</option>
                <option value="eco">Эко (переработка)</option>
                <option value="premium">Премиум дизайнерская</option>
              </select>
            </div>
            {showPages && (
              <div className="calc-field">
                <label>Отделка обложки</label>
                <select value={finish} onChange={(e) => setFinish(e.target.value)}>
                  <option value="none">Без отделки</option>
                  <option value="laminate">Ламинация</option>
                  <option value="foil">Тиснение фольгой</option>
                  <option value="emboss">Конгрев</option>
                </select>
              </div>
            )}
          </div>
          <div className="calc-total">
            <div>
              <div className="lbl">Оценка</div>
              <div className="val"><span className="num">{fmt(price.total)}</span>&nbsp;₽</div>
              <div className="range">от {fmt(price.low)} до {fmt(price.high)} ₽</div>
            </div>
            <a href="#cta" className="btn primary" onClick={(e) => { e.preventDefault(); document.getElementById('cta')?.scrollIntoView({behavior: 'smooth'}); }}>Оформить →</a>
          </div>
        </div>
      </div>
    </section>
  );
}

