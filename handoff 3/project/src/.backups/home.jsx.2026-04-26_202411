function CTASection() {
  const [step, setStep] = useStateH(0);
  const [form, setForm] = useStateH({ name: '', phone: '', product: '', qty: '', comment: '' });
  const [sent, setSent] = useStateH(false);

  const update = (k, v) => setForm({ ...form, [k]: v });
  const canNext = () => {
    if (step === 0) return form.product;
    if (step === 1) return form.qty;
    if (step === 2) return form.name && form.phone;
    return true;
  };

  if (sent) {
    return (
      <section className="cta" id="cta">
        <div className="wrap" style={{ textAlign: 'center', maxWidth: 700, margin: '0 auto' }}>
          <h2>Заявка отправлена</h2>
          <p className="sub" style={{ margin: '20px auto 0', maxWidth: 500 }}>Менеджер свяжется с вами в течение часа и подготовит расчёт. Спасибо!</p>
        </div>
      </section>
    );
  }

  return (
    <section className="cta" id="cta">
      <div className="wrap cta-grid">
        <div>
          <div className="eyebrow" style={{ marginBottom: 20, color: 'rgba(255,255,255,0.6)' }}>06 — Контакты</div>
          <h2>Обсудим ваш<br/>проект?</h2>
          <p className="sub">Расскажите, что нужно напечатать. Рассчитаем стоимость за 10 минут.</p>
          <div style={{ marginTop: 40, fontFamily: 'var(--font-mono)', fontSize: 12, color: 'rgba(255,255,255,0.6)', letterSpacing: '0.1em' }}>
            <div style={{ marginBottom: 12 }}>ИЛИ НАПИШИТЕ В ЛЮБОЙ МЕССЕНДЖЕР:</div>
            <div style={{ display: 'flex', gap: 12, flexWrap: 'wrap' }}>
              <a href="#" style={{ color: '#fff', textDecoration: 'underline', textUnderlineOffset: 4 }}>Telegram</a>
              <a href="#" style={{ color: '#fff', textDecoration: 'underline', textUnderlineOffset: 4 }}>WhatsApp</a>
              <a href="tel:+73433101337" style={{ color: '#fff', textDecoration: 'underline', textUnderlineOffset: 4 }}>+7 (343) 310-13-37</a>
            </div>
          </div>
        </div>
        <div className="cta-form">
          <div className="step-dots">
            {[0, 1, 2].map(i => (
              <div key={i} className={`dot ${step === i ? 'active' : ''} ${step > i ? 'done' : ''}`} />
            ))}
          </div>
          {step === 0 && (
            <div>
              <div className="step-title">1. Что печатаем?</div>
              <div className="field">
                <label>Тип продукции</label>
                <select value={form.product} onChange={(e) => update('product', e.target.value)}>
                  <option value="">— выберите —</option>
                  {PRODUCTS.map(p => <option key={p.id} value={p.name}>{p.name}</option>)}
                  <option>Другое</option>
                </select>
              </div>
            </div>
          )}
          {step === 1 && (
            <div>
              <div className="step-title">2. Параметры</div>
              <div className="row2">
                <div className="field">
                  <label>Тираж</label>
                  <input type="text" placeholder="Например, 500" value={form.qty} onChange={(e) => update('qty', e.target.value)} />
                </div>
                <div className="field">
                  <label>Сроки</label>
                  <select defaultValue="">
                    <option value="">— любые —</option>
                    <option>Срочно (до 3 дней)</option>
                    <option>До 1 недели</option>
                    <option>До 2 недель</option>
                    <option>Не срочно</option>
                  </select>
                </div>
              </div>
              <div className="field" style={{ marginTop: 14 }}>
                <label>Комментарий</label>
                <textarea placeholder="Бумага, отделка, особые пожелания…" value={form.comment} onChange={(e) => update('comment', e.target.value)} />
              </div>
            </div>
          )}
          {step === 2 && (
            <div>
              <div className="step-title">3. Куда отправить расчёт?</div>
              <div className="field"><label>Ваше имя</label><input type="text" placeholder="Имя" value={form.name} onChange={(e) => update('name', e.target.value)} /></div>
              <div className="field"><label>Телефон</label><input type="tel" placeholder="+7" value={form.phone} onChange={(e) => update('phone', e.target.value)} /></div>
              <div style={{ fontSize: 11, color: 'rgba(255,255,255,0.5)', marginTop: 8, lineHeight: 1.4 }}>
                Нажимая «Отправить», вы соглашаетесь с политикой конфиденциальности.
              </div>
            </div>
          )}
          <div className="step-nav">
            {step > 0 && <button className="back" onClick={() => setStep(step - 1)}>Назад</button>}
            {step < 2 && <button className="next" onClick={() => canNext() && setStep(step + 1)} disabled={!canNext()} style={{ opacity: canNext() ? 1 : 0.5 }}>Далее →</button>}
            {step === 2 && <button className="next" onClick={() => canNext() && setSent(true)} disabled={!canNext()} style={{ opacity: canNext() ? 1 : 0.5 }}>Отправить заявку</button>}
          </div>
        </div>
      </div>
    </section>
  );
}

