  .cta-form input::placeholder, .cta-form textarea::placeholder { color: rgba(255,255,255,0.4); }
  .cta-form input:focus, .cta-form select:focus, .cta-form textarea:focus { border-color: #fff; }
  .cta-form textarea { resize: none; min-height: 80px; }
  .cta-form .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .cta-form .btn-submit {
