  .step-nav .back { border: 1px solid rgba(255,255,255,0.3); color: #fff; }
  .step-title { font-family: var(--font-display); font-size: 20px; margin-bottom: 14px; font-weight: 500; }
  body[data-style="presse"] .step-title { font-family: var(--font-body); font-weight: 600; }

  /* ========== FOOTER ========== */
  footer.site { padding: 80px 0 40px; background: var(--ink); color: rgba(255,255,255,0.7); }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 56px; }
