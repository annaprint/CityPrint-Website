    color: rgba(255,255,255,0.7); background: transparent;
    transition: all .15s;
  }
  .tweaks-options button:hover { color: #fff; border-color: rgba(255,255,255,0.35); }
  .tweaks-options button.active { background: #fff; color: #111; border-color: #fff; }
  .tweaks-swatches { display: flex; gap: 8px; }
  .tweaks-swatches button { width: 28px; height: 28px; border-radius: 50%; border: 2px solid transparent; transition: border-color .2s; }
  .tweaks-swatches button.active { border-color: #fff; }

  /* ========== SUBPAGES (in-page navigation) ========== */
  .page { display: none; }
  .page.active { display: block; }

  /* Product detail */
  .pd-hero { padding: 140px 0 60px; }
  .pd-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  @media (max-width: 860px) { .pd-grid { grid-template-columns: 1fr; } }
  .pd-image { aspect-ratio: 4/5; border-radius: 18px; overflow: hidden; position: sticky; top: 100px; }
  body[data-style="presse"] .pd-image { border-radius: 4px; }
  .pd-gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; }
  .pd-gallery .ph { aspect-ratio: 1; border-radius: 6px; cursor: pointer; opacity: 0.6; transition: opacity .2s; }
  .pd-gallery .ph.active, .pd-gallery .ph:hover { opacity: 1; }
  .pd-title { font-family: var(--font-display); font-size: clamp(40px, 5vw, 72px); font-weight: 300; line-height: 0.95; letter-spacing: -0.02em; margin-top: 16px; }
  body[data-style="presse"] .pd-title { font-family: var(--font-body); font-weight: 500; }
  .pd-lead { font-size: 17px; color: var(--muted); margin: 24px 0 36px; line-height: 1.55; }
  .spec-table { border-top: 1px solid var(--line); margin-top: 32px; }
  .spec-row { padding: 16px 0; border-bottom: 1px solid var(--line); display: grid; grid-template-columns: 160px 1fr; gap: 24px; font-size: 14px; }
  .spec-row .k { color: var(--muted); font-family: var(--font-mono); text-transform: uppercase; font-size: 11px; letter-spacing: 0.08em; }
  .options-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .options-chips button {
    padding: 10px 16px; font-size: 13px; border: 1px solid var(--line); border-radius: 999px;
    transition: all .15s;
  }
  body[data-style="presse"] .options-chips button { border-radius: 2px; }
  .options-chips button.active, .options-chips button:hover { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  body[data-style="riso"] .options-chips button.active { background: var(--accent); border-color: var(--accent); }

  /* About page */
  .about-hero { padding: 140px 0 60px; }
  .about-lede { font-family: var(--font-display); font-size: clamp(28px, 3.8vw, 52px); font-weight: 300; line-height: 1.1; letter-spacing: -0.02em; max-width: 900px; }
  body[data-style="presse"] .about-lede { font-family: var(--font-body); font-weight: 400; }
  .about-lede em { font-style: italic; color: var(--accent); }
  .about-body { padding: 40px 0 100px; display: grid; grid-template-columns: 1fr 2fr; gap: 64px; }
  @media (max-width: 860px) { .about-body { grid-template-columns: 1fr; } }
  .about-body .label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
  .about-body p { font-size: 16px; line-height: 1.7; margin-bottom: 18px; }
  .timeline { margin-top: 48px; }
  .timeline-item { padding: 24px 0; border-top: 1px solid var(--line); display: grid; grid-template-columns: 100px 1fr 2fr; gap: 24px; align-items: start; }
  .timeline-year { font-family: var(--font-display); font-size: 28px; font-weight: 400; color: var(--accent); }
  body[data-style="presse"] .timeline-year { font-family: var(--font-body); font-weight: 600; }
  .timeline-title { font-family: var(--font-display); font-size: 18px; font-weight: 500; }
  body[data-style="presse"] .timeline-title { font-family: var(--font-body); font-weight: 600; }
  .timeline-desc { color: var(--muted); font-size: 14px; line-height: 1.6; }

  /* Portfolio page expansion */
  .pf-page-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding-top: 40px; }
  @media (max-width: 860px) { .pf-page-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .pf-page-grid { grid-template-columns: 1fr; } }
  .pf-page-grid .portfolio-item { aspect-ratio: 4/3; }
  .pf-filter { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }
  .pf-filter button {
    padding: 10px 18px; font-size: 13px; border: 1px solid var(--line); border-radius: 999px;
    transition: all .15s; color: var(--muted);
  }
  body[data-style="presse"] .pf-filter button { border-radius: 2px; }
  .pf-filter button.active { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  body[data-style="riso"] .pf-filter button.active { background: var(--accent); border-color: var(--accent); color: #fff; }

  /* ========== STYLE-SPECIFIC OVERLAYS ========== */
  /* Presse: registration marks and grid lines in hero */
  body[data-style="presse"] .hero::before {
    content: ''; position: absolute; top: 140px; right: 48px; width: 40px; height: 40px;
    background:
      linear-gradient(#111, #111) center/1px 100% no-repeat,
      linear-gradient(#111, #111) center/100% 1px no-repeat;
    border: 1px solid #111; border-radius: 50%;
    pointer-events: none;
    opacity: 0.4;
  }
  body[data-style="presse"] .hero::after {
    content: 'REG ⊕ CMYK'; position: absolute; top: 190px; right: 48px;
    font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em; opacity: 0.4;
    pointer-events: none;
  }

  /* Riso: paper texture */
  body[data-style="riso"]::before {
    content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 1;
    background-image: radial-gradient(circle at 1px 1px, rgba(31,27,23,0.04) 1px, transparent 1.5px);
    background-size: 4px 4px;
  }

  /* Atelier: italic ligature-friendly display */
  body[data-style="atelier"] .italic-swash { font-style: italic; font-family: var(--font-display); }

  /* Mobile bottom bar */
  .mobile-cta {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 40;
    padding: 12px; display: none; gap: 10px;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--line);
  }
  @media (max-width: 720px) { .mobile-cta { display: flex; } body { padding-bottom: 72px; } }
  .mobile-cta a { flex: 1; text-align: center; padding: 12px; border-radius: 999px; font-size: 14px; font-weight: 500; }
  body[data-style="presse"] .mobile-cta a { border-radius: 2px; }
  .mobile-cta a.primary { background: var(--accent); color: #fff; }
  .mobile-cta a.ghost { border: 1px solid var(--line); }

  /* Tweaks toggle indicator bubble */
  .tweak-info {
    position: fixed; left: 20px; bottom: 20px; z-index: 75;
    padding: 10px 14px; border-radius: 999px;
    background: var(--ink); color: var(--paper);
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);
    display: none;
  }
  .tweak-info.show { display: block; animation: fadein .4s; }
  @keyframes fadein { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; } }

  /* Focus visible */
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

/* ========== LANDING PAGE BLOCKS ========== */

