<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Сити Принт — Типография в Екатеринбурге</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { overflow-x: hidden; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font-body); color: var(--fg); background: var(--bg); -webkit-font-smoothing: antialiased; transition: background .4s, color .4s; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; border: none; background: none; color: inherit; }
  input, select, textarea { font: inherit; color: inherit; }
  img { max-width: 100%; display: block; }

  /* ========== STYLE VARIABLES ========== */

  /* Atelier — editorial / luxury print house */
  body[data-style="atelier"] {
    --bg: #f4f1ec;
    --fg: #1a1a1a;
    --muted: #6b6660;
    --line: rgba(26,26,26,0.12);
    --paper: #fbf9f4;
    --ink: #1a1a1a;
    --accent: #b8472c;
    --font-display: 'Fraunces', 'Times New Roman', serif;
    --font-body: 'Manrope', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  body[data-style="atelier"][data-accent="red"]    { --accent: #b8472c; }
  body[data-style="atelier"][data-accent="black"]  { --accent: #1a1a1a; }
  body[data-style="atelier"][data-accent="blue"]   { --accent: #1e3a8a; }
  body[data-style="atelier"][data-accent="green"]  { --accent: #4a5d3a; }

  /* Presse — production / craft */
  body[data-style="presse"] {
    --bg: #ebe7de;
    --fg: #111;
    --muted: #555;
    --line: rgba(17,17,17,0.18);
    --paper: #fff;
    --ink: #111;
    --accent: #d63226;
    --cyan: #00a0d4;
    --magenta: #d63284;
    --yellow: #f5c518;
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Space Grotesk', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  body[data-style="presse"][data-accent="red"]    { --accent: #d63226; }
  body[data-style="presse"][data-accent="black"]  { --accent: #111; }
  body[data-style="presse"][data-accent="blue"]   { --accent: #1850d8; }
  body[data-style="presse"][data-accent="green"]  { --accent: #1d7a3d; }

  /* Risograph — playful spot colors */
  body[data-style="riso"] {
    --bg: #f2ece1;
    --fg: #1f1b17;
    --muted: #6a635a;
    --line: rgba(31,27,23,0.15);
    --paper: #faf5e9;
    --ink: #1f1b17;
    --accent: #e84d2e;
    --riso-blue: #3b5fe2;
    --riso-pink: #ff6ba0;
    --riso-yellow: #f4c430;
    --font-display: 'Fraunces', serif;
    --font-body: 'Space Grotesk', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  body[data-style="riso"][data-accent="red"]    { --accent: #e84d2e; }
  body[data-style="riso"][data-accent="black"]  { --accent: #1f1b17; }
  body[data-style="riso"][data-accent="blue"]   { --accent: #3b5fe2; }
  body[data-style="riso"][data-accent="green"]  { --accent: #2d8659; }

  /* ========== SHARED LAYOUT ========== */
  .wrap { max-width: 1440px; margin: 0 auto; padding: 0 48px; }
  @media (max-width: 720px) { .wrap { padding: 0 20px; } }

  .mono { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
  .eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }

  /* Reveal on load */
  .reveal { opacity: 0; transform: translateY(16px); transition: opacity .9s cubic-bezier(.2,.7,.2,1), transform .9s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: none; }

  /* Word reveal for hero */
  .word-reveal span { display: inline-block; opacity: 0; transform: translateY(24px); transition: opacity .8s ease, transform .8s cubic-bezier(.2,.7,.2,1); }
  .word-reveal.in span { opacity: 1; transform: none; }
  .word-reveal span.italic { font-style: italic; color: var(--accent); font-family: var(--font-display); }

  /* ========== HEADER ========== */
  header.site {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    padding: 18px 0;
    backdrop-filter: blur(12px);
    background: color-mix(in oklab, var(--bg) 85%, transparent);
    border-bottom: 1px solid var(--line);
  }
  header.site .bar { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .brand-mark { display: flex; align-items: center; gap: 10px; font-family: var(--font-display); font-size: 22px; font-weight: 500; letter-spacing: -0.01em; }
  .brand-mark { text-decoration: none; }
  .brand-mark:hover { opacity: 0.8; }

  nav.primary { display: flex; gap: 28px; font-size: 14px; }
  nav.primary a { color: var(--muted); transition: color .2s; position: relative; }
  nav.primary a:hover { color: var(--fg); }
  nav.primary a.active { color: var(--fg); }
  nav.primary a.active::after { content: ''; position: absolute; left: 0; right: 0; bottom: -6px; height: 2px; background: var(--accent); }
  @media (max-width: 820px) { nav.primary { display: none; } }

  .header-cta { display: flex; align-items: center; gap: 14px; }
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 22px; font-size: 14px; font-weight: 500;
    border-radius: 999px; transition: all .2s;
  }
  .btn.primary { background: var(--ink); color: var(--paper); }
  .btn.primary:hover { background: var(--accent); transform: translateY(-1px); }
  .btn.ghost { border: 1px solid var(--line); }
  .btn.ghost:hover { border-color: var(--fg); }
  body[data-style="presse"] .btn.primary { border-radius: 4px; background: var(--accent); color: #fff; }
  body[data-style="riso"] .btn.primary { background: var(--accent); color: #fff; box-shadow: 3px 3px 0 var(--ink); }
  body[data-style="riso"] .btn.primary:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--ink); }

  /* ========== HERO ========== */
  section.hero { padding: 140px 0 80px; position: relative; }
  .hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: end; }
  @media (max-width: 960px) { .hero-grid { grid-template-columns: 1fr; gap: 40px; } }

  h1.hero-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 7.2vw, 112px);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.025em;
  }
  body[data-style="presse"] h1.hero-title { font-family: var(--font-body); font-weight: 500; letter-spacing: -0.03em; }
  body[data-style="riso"] h1.hero-title { font-weight: 400; }

  .hero-sub { margin-top: 28px; font-size: 18px; line-height: 1.55; color: var(--muted); max-width: 460px; font-weight: 300; }
  body[data-style="presse"] .hero-sub { font-weight: 400; max-width: 500px; }

  .hero-meta {
    margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--line);
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  }
  @media (max-width: 720px) { .hero-meta { grid-template-columns: repeat(2, 1fr); } }
  .stat-num { font-family: var(--font-display); font-size: 42px; font-weight: 300; line-height: 1; letter-spacing: -0.02em; color: var(--accent); }
  body[data-style="presse"] .stat-num { font-family: var(--font-body); font-weight: 500; }
  .stat-lbl { margin-top: 8px; font-size: 12px; color: var(--muted); line-height: 1.3; }

  /* Calculator variant */
  .calc-card {
    background: var(--paper); border: 1px solid var(--line); border-radius: 18px;
    padding: 28px; box-shadow: 0 20px 60px -30px rgba(0,0,0,0.15);
  }
  body[data-style="presse"] .calc-card { border-radius: 4px; border-width: 1.5px; box-shadow: 6px 6px 0 var(--ink); }
  body[data-style="riso"] .calc-card { border-radius: 20px; box-shadow: 5px 5px 0 var(--ink); }
  .calc-card h3 { font-family: var(--font-display); font-size: 22px; font-weight: 500; margin-bottom: 4px; letter-spacing: -0.01em; }
  body[data-style="presse"] .calc-card h3 { font-family: var(--font-body); font-weight: 600; }
  .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }
  .calc-field { display: flex; flex-direction: column; gap: 6px; }
  .calc-field label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); font-family: var(--font-mono); }
  .calc-field select, .calc-field input {
    padding: 12px 14px; border: 1px solid var(--line); border-radius: 10px;
    background: var(--bg); font-size: 14px; outline: none;
    transition: border-color .15s;
  }
  body[data-style="presse"] .calc-field select,
  body[data-style="presse"] .calc-field input { border-radius: 2px; }
  .calc-field select:focus, .calc-field input:focus { border-color: var(--accent); }
  .calc-total {
    margin-top: 20px; padding-top: 20px; border-top: 1px dashed var(--line);
    display: flex; align-items: baseline; justify-content: space-between; gap: 12px;
  }
  .calc-total .lbl { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; font-family: var(--font-mono); }
  .calc-total .val { font-family: var(--font-display); font-size: 38px; font-weight: 400; color: var(--accent); letter-spacing: -0.02em; }
  body[data-style="presse"] .calc-total .val { font-family: var(--font-body); font-weight: 600; }
  .calc-total .range { font-size: 11px; color: var(--muted); font-family: var(--font-mono); }
  .calc-total .num { font-variant-numeric: tabular-nums; }

  /* Visual/image variant */
  .hero-visual { aspect-ratio: 4/5; border-radius: 18px; overflow: hidden; position: relative; background: var(--paper); border: 1px solid var(--line); }
  body[data-style="presse"] .hero-visual { border-radius: 4px; }
  body[data-style="riso"] .hero-visual { border-radius: 20px; }

  /* Placeholder system */
  .ph { position: relative; overflow: hidden; background: var(--paper); width: 100%; height: 100%; min-height: 100%; }
  .ph::before {
    content: ''; position: absolute; inset: 0;
    background-image: repeating-linear-gradient(45deg, transparent 0 10px, color-mix(in oklab, var(--fg) 4%, transparent) 10px 11px);
  }
  .ph .ph-label {
    position: absolute; left: 16px; bottom: 16px; font-family: var(--font-mono); font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); background: var(--paper);
    padding: 4px 8px; border: 1px solid var(--line);
  }
  .ph.has-img::before { display: none; }
  .ph.has-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ph .ph-label.on-img { background: rgba(255,255,255,0.92); border-color: rgba(0,0,0,0.08); color: #111; }
  body[data-style="riso"] .ph.has-img img { filter: saturate(0.85) contrast(0.95); }
  body[data-style="riso"] .ph.has-img::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background-image: radial-gradient(circle at 2px 2px, color-mix(in oklab, var(--accent) 35%, transparent) 1px, transparent 1.5px);
    background-size: 7px 7px; mix-blend-mode: multiply;
  }
  body[data-style="presse"] .ph::before {
    background-image:
      repeating-linear-gradient(0deg, transparent 0 16px, color-mix(in oklab, var(--fg) 6%, transparent) 16px 17px),
      repeating-linear-gradient(90deg, transparent 0 16px, color-mix(in oklab, var(--fg) 6%, transparent) 16px 17px);
  }
  body[data-style="riso"] .ph { background: color-mix(in oklab, var(--accent) 10%, var(--paper)); }
  body[data-style="riso"] .ph::before {
    background-image: radial-gradient(circle at 2px 2px, color-mix(in oklab, var(--accent) 40%, transparent) 1.5px, transparent 1.5px);
    background-size: 8px 8px;
    mix-blend-mode: multiply;
  }

  /* ========== MARQUEE (running samples) ========== */
  .marquee { padding: 24px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); overflow: hidden; background: var(--paper); }
  .marquee-track { display: flex; gap: 48px; animation: scroll 40s linear infinite; width: max-content; align-items: center; }
  .marquee-track > * { white-space: nowrap; flex-shrink: 0; }
  .marquee-item { font-family: var(--font-display); font-size: 28px; font-weight: 400; letter-spacing: -0.01em; }
  body[data-style="presse"] .marquee-item { font-family: var(--font-body); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .marquee-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  @keyframes scroll { to { transform: translateX(-50%); } }

  /* ========== PRODUCTS ========== */
  section.products { padding: 100px 0; }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 24px; margin-bottom: 56px; }
  .section-head h2 {
    font-family: var(--font-display); font-size: clamp(34px, 4.6vw, 64px); font-weight: 300; letter-spacing: -0.02em; line-height: 1;
  }
  body[data-style="presse"] .section-head h2 { font-family: var(--font-body); font-weight: 500; }
  .section-head .sub { color: var(--muted); font-size: 16px; max-width: 360px; margin-top: 14px; }

  .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  @media (max-width: 1100px) { .products-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 760px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .products-grid { grid-template-columns: 1fr; } }

  .product-card {
    display: block; background: var(--paper); border: 1px solid var(--line); border-radius: 14px; overflow: hidden;
    transition: transform .3s ease, box-shadow .3s ease;
  }
  body[data-style="presse"] .product-card { border-radius: 2px; }
  body[data-style="riso"] .product-card { border-radius: 18px; }
  .product-card:hover { transform: translateY(-6px); box-shadow: 0 20px 40px -20px rgba(0,0,0,0.2); }
  body[data-style="riso"] .product-card:hover { transform: translate(-3px, -3px); box-shadow: 6px 6px 0 var(--ink); }
  .product-card .ph { aspect-ratio: 4/3; height: auto; min-height: 0; }
  .product-card .meta { padding: 18px; }
  .product-card h3 { font-family: var(--font-display); font-size: 20px; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 4px; }
  body[data-style="presse"] .product-card h3 { font-family: var(--font-body); font-weight: 500; }
  .product-card .note { font-size: 12px; color: var(--muted); font-family: var(--font-mono); }

  /* ========== PORTFOLIO ========== */
  section.portfolio { padding: 100px 0; background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .portfolio-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: auto auto; gap: 16px; }
  .portfolio-grid > *:nth-child(1) { grid-row: span 2; aspect-ratio: 3/4; }
  .portfolio-grid > *:nth-child(2) { aspect-ratio: 4/3; }
  .portfolio-grid > *:nth-child(3) { aspect-ratio: 4/3; }
  .portfolio-grid > *:nth-child(4) { aspect-ratio: 4/3; }
  .portfolio-grid > *:nth-child(5) { aspect-ratio: 4/3; }
  @media (max-width: 860px) { .portfolio-grid { grid-template-columns: 1fr 1fr; } .portfolio-grid > *:nth-child(1) { grid-row: auto; aspect-ratio: 1; } }

  .portfolio-item {
    position: relative; overflow: hidden; border-radius: 10px; cursor: pointer; transition: transform .3s;
    border: 1px solid var(--line);
  }
  body[data-style="presse"] .portfolio-item { border-radius: 2px; }
  body[data-style="riso"] .portfolio-item { border-radius: 16px; }
  .portfolio-item:hover { transform: scale(0.985); }
  .portfolio-item .caption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 18px 20px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: #fff;
    opacity: 0; transition: opacity .3s;
  }
  .portfolio-item:hover .caption { opacity: 1; }
  .portfolio-item .caption h4 { font-family: var(--font-display); font-size: 18px; font-weight: 500; }
  .portfolio-item .caption p { font-size: 11px; opacity: 0.75; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }

  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0; z-index: 100; background: rgba(10,8,6,0.92);
    display: none; align-items: center; justify-content: center; padding: 40px;
  }
  .lightbox.open { display: flex; }
  .lightbox-inner { max-width: 1100px; width: 100%; position: relative; }
  .lightbox-image { width: 100%; aspect-ratio: 16/10; border-radius: 12px; background: var(--paper); position: relative; overflow: hidden; }
  .lightbox-caption { margin-top: 20px; color: #fff; display: flex; justify-content: space-between; gap: 24px; align-items: end; }
  .lightbox-caption h4 { font-family: var(--font-display); font-size: 28px; font-weight: 400; }
  .lightbox-caption p { color: rgba(255,255,255,0.65); font-size: 14px; max-width: 500px; margin-top: 4px; }
  .lightbox-nav { display: flex; gap: 12px; }
  .lightbox-nav button, .lightbox-close {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,255,255,0.1); color: #fff;
    display: grid; place-items: center;
    transition: background .2s;
  }
  .lightbox-nav button:hover, .lightbox-close:hover { background: rgba(255,255,255,0.2); }
  .lightbox-close { position: absolute; top: -20px; right: 0; }
  .lightbox-counter { font-family: var(--font-mono); font-size: 12px; color: rgba(255,255,255,0.65); letter-spacing: 0.1em; }

  /* ========== WHY ========== */
  section.why { padding: 100px 0; }
  .why-list { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 56px; }
  @media (max-width: 960px) { .why-list { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .why-list { grid-template-columns: 1fr; } }
  .why-item { padding: 28px; border: 1px solid var(--line); border-radius: 14px; background: var(--paper); transition: border-color .25s; }
  body[data-style="presse"] .why-item { border-radius: 2px; border-width: 1.5px; }
  body[data-style="riso"] .why-item { border-radius: 18px; }
  .why-item:hover { border-color: var(--accent); }
  .why-num { font-family: var(--font-mono); font-size: 11px; color: var(--accent); letter-spacing: 0.12em; }
  .why-item h3 { font-family: var(--font-display); font-size: 22px; font-weight: 500; margin: 18px 0 10px; letter-spacing: -0.01em; }
  body[data-style="presse"] .why-item h3 { font-family: var(--font-body); font-weight: 600; }
  .why-item p { font-size: 14px; color: var(--muted); line-height: 1.55; }

  /* ========== MATERIAL (Atelier-inspired) ========== */
  section.material { padding: 100px 0; background: var(--ink); color: var(--paper); }
  section.material .section-head h2 { color: var(--paper); }
  section.material .section-head .sub { color: rgba(255,255,255,0.6); }
  .material-row { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  @media (max-width: 860px) { .material-row { grid-template-columns: 1fr; } }
  .material-copy p { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 16px; max-width: 480px; }
  .material-pull {
    font-family: var(--font-display); font-size: clamp(28px, 3.6vw, 48px); font-weight: 300;
    line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 32px;
  }
  body[data-style="presse"] .material-pull { font-family: var(--font-body); font-weight: 500; }
  .material-pull em { font-style: italic; color: var(--accent); }
  .material-visual { aspect-ratio: 4/5; border-radius: 18px; overflow: hidden; background: #2a2622; position: relative; }

  /* ========== REVIEWS ========== */
  section.reviews { padding: 100px 0; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 860px) { .reviews-grid { grid-template-columns: 1fr; } }
  .review { padding: 32px; background: var(--paper); border: 1px solid var(--line); border-radius: 14px; }
  body[data-style="presse"] .review { border-radius: 2px; border-width: 1.5px; }
  body[data-style="riso"] .review { border-radius: 18px; }
  .review .qmark { font-family: var(--font-display); font-size: 52px; line-height: 0.5; color: var(--accent); }
  .review blockquote { font-size: 16px; line-height: 1.55; margin: 20px 0 24px; }
  .review cite { font-style: normal; }
  .review cite strong { font-family: var(--font-display); font-size: 18px; font-weight: 500; }
  body[data-style="presse"] .review cite strong { font-family: var(--font-body); font-weight: 600; }
  .review cite small { display: block; margin-top: 2px; font-size: 11px; color: var(--muted); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.08em; }

  /* ========== LOGOS ========== */
  .clients { padding: 32px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); overflow: hidden; }
  .clients-track { display: flex; gap: 56px; animation: scroll 30s linear infinite; width: max-content; align-items: center; }
