  .tweaks-panel.open { display: block; }
  .tweaks-panel h5 { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 10px; color: rgba(255,255,255,0.5); font-family: 'JetBrains Mono', monospace; }
  .tweaks-panel .title { font-size: 14px; font-weight: 600; margin-bottom: 14px; display: flex; justify-content: space-between; align-items: center; }
  .tweaks-panel .close { color: rgba(255,255,255,0.6); font-size: 18px; cursor: pointer; }
  .tweaks-panel .group { margin-bottom: 16px; }
  .tweaks-options { display: flex; gap: 6px; flex-wrap: wrap; }
  .tweaks-options button {
    padding: 8px 12px; font-size: 12px;
